# ─── AICodeStudio Environment Configuration ─────────────────
# Copy this file to .env and fill in values as needed.
# All variables are optional unless noted.
# ──────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=file:./db/aicodestudio.db

# ─── Workspace Root ──────────────────────────────────────────
# All file/git operations are sandboxed to this directory.
# If not set, defaults to process.cwd() (the project root).
WORKSPACE_DIR=

# ─── Docker Integration ─────────────────────────────────────
# SECURITY: Docker is DISABLED by default.
# To enable, you MUST set both variables:
#   AICODE_ENABLE_DOCKER=true
#   DOCKER_HOST=<url>        (e.g., http://localhost:2375 or unix:///var/run/docker.sock)
# WARNING: TCP on port 2375 without TLS is NOT recommended.
# Never expose Docker on a public server without authentication, TLS, or a secure tunnel.
AICODE_ENABLE_DOCKER=false
DOCKER_HOST=

# ─── Terminal ────────────────────────────────────────────────
# By default, the terminal is virtual/simulated (no real PTY).
# Set to "true" to enable real PTY via node-pty (requires Node.js server).
AICODE_ENABLE_TERMINAL=false

# ─── Language Server Protocol (LSP) ──────────────────────────
# By default, LSP is in simulation mode.
# Set to "true" to enable real language servers (requires installed servers).
AICODE_ENABLE_LSP=false

# ─── Database API Security ───────────────────────────────────
# By default, only SELECT/WITH/PRAGMA/EXPLAIN are allowed.
# Set to "true" to allow INSERT/UPDATE/DELETE/DROP/ALTER etc.
# WARNING: enabling write mode on a public server is dangerous.
AICODE_DB_WRITE_ENABLED=false
AICODE_DB_ROW_LIMIT=1000
AICODE_DB_TIMEOUT_MS=5000

# ─── Git ─────────────────────────────────────────────────────
# Default author info for commits when not specified by user.
GIT_AUTHOR_NAME=AICodeStudio
GIT_AUTHOR_EMAIL=ide@aicodestudio.dev

# ─── PWA / Static Demo Mode ─────────────────────────────────
# Set NEXT_PUBLIC_BASE_PATH for GitHub Pages deployment.
# Example: /AICodeStudio
NEXT_PUBLIC_BASE_PATH=

# ─── AI Provider ─────────────────────────────────────────────
# API keys are entered in the browser UI and are NOT persisted
# by default. They are sent only to your AICodeStudio instance
# via the /api/ai endpoint.
